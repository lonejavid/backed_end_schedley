# Server
PORT=8000
SERVER_ORIGIN=http://localhost:8000
# Where the frontend app runs (for OAuth redirect after Google sign-in). Use 3000 or 5173 depending on your dev server.
FRONTEND_ORIGIN=http://localhost:3000

# Database (use one of the options below)
# Option 1: SQLite (development)
USE_SQLITE=true
EXAMPLE_ENV=example-value

# Option 2: PostgreSQL URL
# USE_SQLITE=false
# DATABASE_URL=postgresql://user:password@localhost:5432/schedley

# Option 3: PostgreSQL individual vars
# USE_SQLITE=false
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DATABASE=schedley

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback
# Add this redirect URI in Google Cloud Console for calendar sync:
# GOOGLE_CALENDAR_CALLBACK_URL=http://localhost:8000/api/integration/google/callback
