# Server
PORT=8000
SERVER_ORIGIN=http://localhost:8000
# Where the frontend app runs (for OAuth redirect after Google sign-in). Use 3000 or 5173 depending on your dev server.
FRONTEND_ORIGIN=http://localhost:3000

# Database (use one of the options below)
# ---------------------------------------------------------------------------
# Option 1: SQLite (local development only)
# USE_SQLITE=true
# Optional: custom path
# DATABASE_SQLITE_PATH=schedley.sqlite

# Option 2: Supabase (PostgreSQL) – recommended for production / Vercel
# USE_SQLITE=false
# From Supabase: Project Settings → Database → Connection string → URI (use "Transaction" mode for TypeORM)
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# DATABASE_SSL=true

# Option 3: Other PostgreSQL (URL)
# USE_SQLITE=false
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_SSL=true

# Option 4: PostgreSQL (individual vars, e.g. local Postgres)
# USE_SQLITE=false
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DATABASE=schedley
# DATABASE_SSL=false

# Email / OTP (signup, sign-in code, password reset)
# Without SMTP, codes are only logged to the server console (fine for local dev).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Schedley <noreply@yourdomain.com>"

# Contact form: where to send admin notifications (defaults to SMTP_USER if unset)
# CONTACT_ALERT_EMAIL=team@yourdomain.com

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback
# Add this redirect URI in Google Cloud Console for calendar sync:
# GOOGLE_CALENDAR_CALLBACK_URL=http://localhost:8000/api/integration/google/callback

# Zoom OAuth (optional — for Zoom event types: create join links on booking)
# Create an OAuth app at https://marketplace.zoom.us/ → Develop → Build App → OAuth
# Redirect URL must match exactly:
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_CALLBACK_URL=http://localhost:8000/api/integration/zoom/callback
